# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/discovery_db

# Vector Database Configuration
# Choose one provider: weaviate or chroma
VECTOR_DB_PROVIDER=weaviate

# Weaviate Configuration (if VECTOR_DB_PROVIDER=weaviate)
WEAVIATE_URL=http://localhost:8080
# WEAVIATE_KEY=your-api-key-here  # Uncomment for cloud instances

# ChromaDB Configuration (if VECTOR_DB_PROVIDER=chroma)
# For persistent local mode:
# CHROMA_PERSIST_DIR=./chroma_data

# For client-server mode:
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# LLM Configuration
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-pro-preview

# Article Search Provider Configuration
# Choose which search provider to use for finding web articles
# Options: 'duckduckgo' (default, free, no API key) or 'gemini' (requires GOOGLE_API_KEY)
ARTICLE_SEARCH_PROVIDER=duckduckgo

# Internal Auth (OAuth2 password grant + JWT)
# REQUIRED in production. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
# Set to false to disable open self-registration (invite/admin-only)
ALLOW_REGISTRATION=true
